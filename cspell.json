{
  "version": "0.2",
  "language": "en",
  "globRoot": "./",
  "words": ["unrun"],
  "dictionaryDefinitions": [
    {
      "name": "xiaozhi-words",
      "path": "./.cspell/words.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["xiaozhi-words"],
  "ignorePaths": [
    "docs/content/音色列表.md",
