{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@xiaozhi-client/shared-types": ["../../src/types/index.ts"]
    },
    "outDir": "./dist",
    "rootDir": "../../",
    "composite": true,
    "lib": ["ES2022"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": false,
    "allowJs": false
  },
  "include": ["src/**/*", "../../src/types/**/*"],
  "exclude": ["node_modules", "dist", "__tests__"]
}
