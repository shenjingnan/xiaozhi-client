{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src/cli",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsup",
        "cwd": "src/cli"
      },
      "outputs": ["{workspaceRoot}/dist/cli"],
      "dependsOn": ["backend:build", "config:build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage.enabled=false",
        "cwd": "src/cli"
      },
      "outputs": ["{workspaceRoot}/coverage"]
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest",
        "cwd": "src/cli"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage",
        "cwd": "src/cli"
      },
      "outputs": ["{workspaceRoot}/coverage"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check src/cli"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check --write src/cli"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'CLI type-check skipped: bundled by tsup which strips types'"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsup --watch",
        "cwd": "src/cli"
      },
      "dependsOn": ["backend:build"]
    },
    "nx-release-publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../scripts/publish-with-tag.sh",
        "cwd": "src/cli"
      }
    }
  },
  "tags": ["type:lib", "scope:cli"],
  "implicitDependencies": ["backend"]
}
