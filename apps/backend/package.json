{
  "name": "@xiaozhi-client/backend",
  "version": "1.0.0",
  "deprecated": "DEPRECATED: 已迁移至 src/server/。此包仅保留作为 Nx 项目配置壳。",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production tsup --config ./tsup.config.ts",
    "dev": "cross-env NODE_ENV=development tsup --config ./tsup.config.ts --watch",
    "test": "vitest run --coverage.enabled=false",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "spellcheck": "cspell .",
    "check:cpd": "jscpd . --ignore 'node_modules'",
    "check:all": "pnpm run lint && pnpm run typecheck && pnpm run spellcheck && pnpm run check:cpd",
    "clean:dist": "rimraf ../../dist/backend"
  },
  "dependencies": {
    "@coze/api": "^1.3.9",
    "@discordjs/opus": "^0.10.0",
    "@hono/node-server": "^1.19.10",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "univoice": "^0.10.0",
    "ajv": "^8.18.0",
    "chalk": "^5.6.0",
    "comment-json": "^4.2.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.1",
    "eventsource": "^4.0.0",
    "express": "^5.1.0",
    "hono": "^4.12.7",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "node-cache": "^5.1.2",
    "openai": "^4.73.0",
    "pino": "^10.3.1",
    "prism-media": "^1.3.5",
    "pino-pretty": "^13.1.1",
    "ws": "^8.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/ws": "^8.18.1",
    "happy-dom": "^20.0.2",
    "supertest": "^7.1.4"
  }
}
