{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "../../dist/backend",
    "rootDir": "../../",
    "baseUrl": ".",
    "types": ["vitest/globals"],
    "paths": {
      "@/*": ["./*"],
      "@xiaozhi-client/version": ["../../src/utils/version.ts"],
      "@xiaozhi-client/shared-types": ["../../src/types/index.ts"]
    }
  },
  "include": [
    "./**/*.ts",
    "../../src/utils/version.ts",
    "../../src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/**/*",
    "templates/**/*",
    "**/*.config.ts"
  ]
}
