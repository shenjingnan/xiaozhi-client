{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "extends": ["../../biome.json"],
  "files": {
    "includes": [
      "**/src/**/*.ts",
      "**/src/**/*.tsx",
      "**/*.ts",
      "**/*.js",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/coverage/**"
    ]
  },
  "linter": {
    "rules": {
      "a11y": {
        "useValidAnchor": "off",
        "noSvgWithoutTitle": "off"
      },
      "style": {
        "useImportType": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  }
}
