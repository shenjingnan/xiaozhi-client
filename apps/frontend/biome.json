{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "extends": ["../../biome.json"],
  "files": {
    "includes": [
      "!!**/node_modules",
      "!!**/dist",
      "!!**/coverage",
      "!!**/src/index.css"
    ]
  },
  "linter": {
    "rules": {
      "a11y": {
        "useValidAnchor": "off",
        "noSvgWithoutTitle": "off",
        "noStaticElementInteractions": "off",
        "useSemanticElements": "off"
      },
      "style": {
        "useImportType": "error"
      },
      "suspicious": {
        "noDocumentCookie": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  }
}
